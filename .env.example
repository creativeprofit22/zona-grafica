# Database — use Vercel Postgres, Neon, or Supabase connection string
DATABASE_URL="postgresql://user:password@host:5432/zona_grafica?sslmode=require"

# Admin panel — bcrypt hash of admin password
ADMIN_PASSWORD=

# Session — generate with: openssl rand -hex 32
SESSION_SECRET=

# Optional — comma-separated trusted proxy IPs
# TRUSTED_PROXY_IPS=

# Automatic — set by runtime, do not configure manually:
# NODE_ENV (set by Next.js: development | production | test)
# VERCEL (set automatically on Vercel deployments)
